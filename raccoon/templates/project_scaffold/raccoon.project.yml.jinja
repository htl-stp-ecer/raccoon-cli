name: {{ project_name }}
uuid: {{ project_uuid }}

robot:
  button: button
  drive:
    kinematics:
      type: "mecanum"
      front_left_motor: front_left_motor
      back_left_motor: rear_left_motor
      front_right_motor: front_right_motor
      back_right_motor: rear_right_motor  # ensure each wheel has its own motor channel
      max_acceleration: 240.0            # rad/s² wheel accel ≈ 9 m/s² linear on 7.5 cm wheels
      max_velocity: 40.0                 # rad/s wheel speed ≈ 1.5 m/s chassis top speed
      track_width: 0.19       # meters (centre-to-centre spacing left↔right)
      wheel_radius: 0.03   # meters (150 mm diameter wheels)
      wheelbase: 0.12        # meters (front↔rear axle spacing)

    # Motion limits
    limits:
      max_v: 2.0      # m/s chassis cap to stay within drivetrain power envelope
      max_omega: 10.0 # rad/s yaw cap for quicker heading changes
  odometry:
    type: "FusedOdometry"
    invert_x: false
    invert_y: false
    invert_z: true
    invert_w: false

  # Unified Motion PID Configuration (speed-independent)
  # Keys match UnifiedMotionPidConfig constructor params directly.
  # These values are used by all motion primitives: drive, turn, strafe
  motion_pid:
    # Distance/Position PID (nested PidConfig)
    distance:
      kp: 2.0
      ki: 0.0
      kd: 0.0
      integral_max: 10.0            # Anti-windup limit
      integral_deadband: 0.01       # Don't integrate within this error
      derivative_lpf_alpha: 0.1     # Low-pass filter for derivative term
      output_min: -10.0
      output_max: 10.0

    # Heading/Angular PID (nested PidConfig)
    heading:
      kp: 3.0
      ki: 0.0
      kd: 0.0
      integral_max: 10.0
      integral_deadband: 0.01
      derivative_lpf_alpha: 0.1
      output_min: -10.0
      output_max: 10.0

    # Profiled PID velocity feedforward
    velocity_ff: 1.0

    # Tolerances
    distance_tolerance_m: 0.01
    angle_tolerance_rad: 0.02

    # Saturation handling
    saturation_derating_factor: 0.85
    saturation_min_scale: 0.1
    saturation_recovery_rate: 0.02
    saturation_hold_cycles: 5
    saturation_recovery_threshold: 0.95

    # Heading-specific saturation
    heading_saturation_derating_factor: 0.85
    heading_min_scale: 0.25
    heading_recovery_rate: 0.05
    heading_saturation_error_rad: 0.01
    heading_recovery_error_rad: 0.005

    # Per-axis motion profile constraints (populated by characterize_drive)
    # linear:
    #   max_velocity: 0.0
    #   acceleration: 0.0
    #   deceleration: 0.0
    # lateral:
    #   max_velocity: 0.0
    #   acceleration: 0.0
    #   deceleration: 0.0
    # angular:
    #   max_velocity: 0.0
    #   acceleration: 0.0
    #   deceleration: 0.0             # Minimum translational speed


# They have to be placed in src.missions folder (Filename is snake_case of class name)
# Order matters, first (normal) mission will be executed first
missions:
  - SetupMission: "setup" # Special mission to initialize hardware
  - ShutdownMission: "shutdown" # Special mission to safely shutdown hardware


definitions:
  button:
    type: "DigitalSensor"
    port: 10